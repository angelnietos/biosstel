# pnpm configuration for monorepo
auto-install-peers=true
strict-peer-dependencies=false

# Hoist ALL packages to root node_modules (flat layout like npm)
# This prevents local node_modules in apps/ and libs/
shamefully-hoist=true
hoist=true
hoist-pattern[]=*

# Prevent npm/yarn from being used accidentally
# (also enforced via preinstall script in package.json)

# Allow build scripts for essential packages
onlyBuiltDependencies[]=@nestjs/core
onlyBuiltDependencies[]=@parcel/watcher
onlyBuiltDependencies[]=@swc/core
onlyBuiltDependencies[]=bcrypt
onlyBuiltDependencies[]=nx
onlyBuiltDependencies[]=sharp
onlyBuiltDependencies[]=@scarf/scarf
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=unrs-resolver
